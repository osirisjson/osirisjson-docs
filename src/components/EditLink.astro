---
// Same markup/behavior as @astrojs/starlight/components/EditLink.astro,
// just swapping the pencil <Icon> SVG as OSIRIS JSON use Google Material Symbols Outlined.
const { editUrl } = Astro.locals.starlightRoute;
---

{
	editUrl && (
		<a href={editUrl} class="sl-flex print:hidden">
			<span class="material-symbols-outlined" aria-hidden="true">
				edit
			</span>
			{Astro.locals.t('page.editLink')}
		</a>
	)
}

<style>
	@layer starlight.core {
		a {
			gap: 0.5rem;
			align-items: center;
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		a:hover {
			color: var(--sl-color-text-accent);
		}
		a :global(.material-symbols-outlined) {
			font-size: 1.2em;
		}
	}
</style>
