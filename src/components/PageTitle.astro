---
const PAGE_TITLE_ID = '_top';

const { title } = Astro.locals.starlightRoute.entry.data;
const { lastUpdated, lang } = Astro.locals.starlightRoute;
const lastUpdatedText = lastUpdated
	? lastUpdated.toLocaleDateString(lang, { dateStyle: 'medium', timeZone: 'UTC' })
	: null;
const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

const linkedinShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebookShare = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const xShare = `https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}`;
---

<h1 id={PAGE_TITLE_ID}>{title}</h1>

<div class="article-meta-bar not-content">
	{
		lastUpdatedText && (
			<span class="last-updated">
				Last updated: <time datetime={lastUpdated!.toISOString()}>{lastUpdatedText}</time>
			</span>
		)
	}
	<span class="label">Share</span>
	<button type="button" class="meta-btn icon-btn" data-copy-url aria-label="Copy URL">
		<span class="material-symbols-outlined">link</span>
	</button>
	<a
		href={linkedinShare}
		target="_blank"
		rel="noopener noreferrer"
		class="meta-btn icon-btn"
		aria-label="Share on LinkedIn"
	>
		<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
			<path
				d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
			></path>
		</svg>
	</a>
	<a
		href={facebookShare}
		target="_blank"
		rel="noopener noreferrer"
		class="meta-btn icon-btn"
		aria-label="Share on Facebook"
	>
		<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
			<path
				d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
			></path>
		</svg>
	</a>
	<a
		href={xShare}
		target="_blank"
		rel="noopener noreferrer"
		class="meta-btn icon-btn"
		aria-label="Share on X"
	>
		<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
			<path
				d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
			></path>
		</svg>
	</a>
	<div class="divider" aria-hidden="true"></div>
	<button type="button" class="meta-btn" data-copy-md aria-label="Copy as Markdown">
		<span class="material-symbols-outlined">content_copy</span>
		<span data-copy-md-label>Copy MD</span>
	</button>
	<button type="button" class="meta-btn" data-download-md aria-label="Download as Markdown">
		<span class="material-symbols-outlined">download</span>
		Download MD
	</button>
</div>

<style>
	@layer starlight.core {
		h1 {
			margin-top: 1rem;
			font-size: var(--sl-text-h1);
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
		}
	}

	.article-meta-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin: 1rem 0 1.5rem;
		padding-block: 0.75rem;
		border-block: 1px solid var(--sl-color-hairline);
	}

	.label {
		margin-inline-end: 0.25rem;
		font-size: var(--sl-text-2xs);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--sl-color-gray-3);
	}

	.last-updated {
		margin-inline-end: 0.75rem;
		padding-inline-end: 0.75rem;
		border-inline-end: 1px solid var(--sl-color-hairline);
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}

	.meta-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		height: 2rem;
		padding-inline: 0.625rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 0.5rem;
		background: transparent;
		color: var(--sl-color-text);
		font-size: var(--sl-text-xs);
		font-family: inherit;
		text-decoration: none;
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.meta-btn:hover {
		border-color: var(--sl-color-text-accent);
		color: var(--sl-color-text-accent);
	}

	.meta-btn.icon-btn {
		width: 2rem;
		padding-inline: 0;
		justify-content: center;
	}

	.meta-btn :global(.material-symbols-outlined) {
		font-size: 1.05rem;
	}

	.divider {
		width: 1px;
		height: 1.25rem;
		background: var(--sl-color-hairline);
	}
</style>

<script>
	const htmlToMarkdown = (el: Element): string => {
		const walk = (node: Node, listDepth: number = 0): string => {
			if (node.nodeType === Node.TEXT_NODE) return node.textContent || '';
			if (node.nodeType !== Node.ELEMENT_NODE) return '';
			if ((node as Element).classList?.contains('sl-anchor-link')) return '';
			const tag = (node as Element).tagName.toLowerCase();
			const children = () =>
				Array.from(node.childNodes)
					.map((c) => walk(c, listDepth))
					.join('');
			switch (tag) {
				case 'h1':
					return `# ${children()}\n\n`;
				case 'h2':
					return `## ${children()}\n\n`;
				case 'h3':
					return `### ${children()}\n\n`;
				case 'h4':
					return `#### ${children()}\n\n`;
				case 'h5':
					return `##### ${children()}\n\n`;
				case 'h6':
					return `###### ${children()}\n\n`;
				case 'p':
					return `${children()}\n\n`;
				case 'strong':
				case 'b':
					return `**${children()}**`;
				case 'em':
				case 'i':
					return `*${children()}*`;
				case 'code':
					if ((node.parentElement?.tagName || '').toLowerCase() === 'pre') return children();
					return `\`${children()}\``;
				case 'pre': {
					const code = node.querySelector('code');
					const lang = code?.className?.match(/language-(\w+)/)?.[1] || '';
					const text = code?.textContent || (node as Element).textContent || '';
					return `\`\`\`${lang}\n${text.trim()}\n\`\`\`\n\n`;
				}
				case 'a': {
					const href = (node as HTMLAnchorElement).getAttribute('href') || '';
					return `[${children()}](${href})`;
				}
				case 'img': {
					const src = (node as HTMLImageElement).getAttribute('src') || '';
					const alt = (node as HTMLImageElement).getAttribute('alt') || '';
					return `![${alt}](${src})\n\n`;
				}
				case 'ul':
					return (
						Array.from(node.childNodes)
							.map((c) => walk(c, listDepth))
							.join('') + '\n'
					);
				case 'ol':
					return (
						Array.from(node.childNodes)
							.map((c) => walk(c, listDepth))
							.join('') + '\n'
					);
				case 'li': {
					const prefix =
						(node.parentElement?.tagName || '').toLowerCase() === 'ol'
							? `${'  '.repeat(listDepth)}1. `
							: `${'  '.repeat(listDepth)}- `;
					return `${prefix}${children().trim()}\n`;
				}
				case 'blockquote':
					return (
						children()
							.split('\n')
							.filter(Boolean)
							.map((l: string) => `> ${l}`)
							.join('\n') + '\n\n'
					);
				case 'hr':
					return '---\n\n';
				case 'br':
					return '\n';
				case 'table': {
					const rows = Array.from((node as Element).querySelectorAll('tr'));
					if (rows.length === 0) return '';
					const toRow = (tr: Element) =>
						Array.from(tr.querySelectorAll('th, td')).map((c) => walk(c, listDepth).trim());
					const header = toRow(rows[0]!);
					const sep = header.map(() => '---');
					const body = rows.slice(1).map((r) => toRow(r));
					const fmt = (cols: string[]) => `| ${cols.join(' | ')} |`;
					return [fmt(header), fmt(sep), ...body.map(fmt)].join('\n') + '\n\n';
				}
				default:
					return children();
			}
		};
		return walk(el)
			.replace(/\n{3,}/g, '\n\n')
			.trim();
	};

	const getArticleMarkdown = (): string => {
		const content = document.querySelector('.sl-markdown-content');
		const titleEl = document.querySelector('h1');
		const title = titleEl?.textContent?.trim() || 'Document';
		let md = `# ${title}\n\n`;
		if (content) md += `${htmlToMarkdown(content)}\n\n`;
		md += `---\n\nSource: ${window.location.href}\n`;
		return md;
	};

	const copyText = async (text: string): Promise<void> => {
		try {
			await navigator.clipboard.writeText(text);
		} catch {
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.style.position = 'fixed';
			ta.style.opacity = '0';
			document.body.appendChild(ta);
			ta.select();
			document.execCommand('copy');
			ta.remove();
		}
	};

	const initShareButtons = () => {
		const copyUrlBtn = document.querySelector<HTMLButtonElement>('[data-copy-url]');
		copyUrlBtn?.addEventListener('click', async () => {
			const icon = copyUrlBtn.querySelector('.material-symbols-outlined');
			await copyText(window.location.href);
			if (icon) {
				icon.textContent = 'check';
				setTimeout(() => {
					icon.textContent = 'link';
				}, 2000);
			}
		});

		const copyBtn = document.querySelector<HTMLButtonElement>('[data-copy-md]');
		const copyLabel = document.querySelector<HTMLSpanElement>('[data-copy-md-label]');
		copyBtn?.addEventListener('click', async () => {
			await copyText(getArticleMarkdown());
			if (copyLabel) {
				const orig = copyLabel.textContent;
				copyLabel.textContent = 'Copied!';
				setTimeout(() => {
					copyLabel.textContent = orig;
				}, 2000);
			}
		});

		const downloadBtn = document.querySelector<HTMLButtonElement>('[data-download-md]');
		downloadBtn?.addEventListener('click', () => {
			const md = getArticleMarkdown();
			const slug = window.location.pathname.split('/').filter(Boolean).pop() || 'document';
			const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
			const url = URL.createObjectURL(blob);
			const a = document.createElement('a');
			a.href = url;
			a.download = `${slug}.md`;
			document.body.appendChild(a);
			a.click();
			a.remove();
			URL.revokeObjectURL(url);
		});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initShareButtons, { once: true });
	} else {
		initShareButtons();
	}
</script>
